@inject SignInManager<IdentityUser> SignInManager
@{
    var hasExternalLogins = (await SignInManager.GetExternalAuthenticationSchemesAsync()).Any();
}
<ul class="flex flex-col gap-1">
    <li><a class="block px-3 py-2 rounded-lg text-sm text-gray-600 hover:bg-gray-100 @ManageNavPages.IndexNavClass(ViewContext)" id="profile" asp-page="./Index">Profil</a></li>
    <li><a class="block px-3 py-2 rounded-lg text-sm text-gray-600 hover:bg-gray-100 @ManageNavPages.EmailNavClass(ViewContext)" id="email" asp-page="./Email">E-post</a></li>
    <li><a class="block px-3 py-2 rounded-lg text-sm text-gray-600 hover:bg-gray-100 @ManageNavPages.ChangePasswordNavClass(ViewContext)" id="change-password" asp-page="./ChangePassword">Passord</a></li>
    @if (hasExternalLogins)
    {
        <li><a class="block px-3 py-2 rounded-lg text-sm text-gray-600 hover:bg-gray-100 @ManageNavPages.ExternalLoginsNavClass(ViewContext)" id="external-login" asp-page="./ExternalLogins">Eksterne innlogginger</a></li>
    }
    <li><a class="block px-3 py-2 rounded-lg text-sm text-gray-600 hover:bg-gray-100 @ManageNavPages.TwoFactorAuthenticationNavClass(ViewContext)" id="two-factor" asp-page="./TwoFactorAuthentication">To-faktor</a></li>
    <li><a class="block px-3 py-2 rounded-lg text-sm text-gray-600 hover:bg-gray-100 @ManageNavPages.PersonalDataNavClass(ViewContext)" id="personal-data" asp-page="./PersonalData">Persondata</a></li>
</ul>