@page
@model EmailModel
@{
    ViewData["Title"] = "E-post";
    ViewData["ActivePage"] = ManageNavPages.Email;
}

<partial name="_StatusMessage" for="StatusMessage" />

<div class="bg-gray-800 rounded-xl shadow border border-gray-700 p-6">
    <form id="email-form" method="post">
        <div asp-validation-summary="All" class="text-red-400 text-sm mb-4" role="alert"></div>

        <div class="mb-4">
            <label asp-for="Email" class="block text-sm font-medium text-gray-300 mb-1">Nåværende e-post</label>
            @if (Model.IsEmailConfirmed)
            {
                <div class="flex items-center gap-2">
                    <input asp-for="Email" class="w-full bg-gray-700 border border-gray-600 rounded-lg px-3 py-2 text-sm text-gray-400 cursor-not-allowed" disabled />
                    <span class="text-green-400 font-bold text-lg">✓</span>
                </div>
            }
            else
            {
                <input asp-for="Email" class="w-full bg-gray-700 border border-gray-600 rounded-lg px-3 py-2 text-sm text-gray-400 cursor-not-allowed" disabled />
                <button id="email-verification" type="submit" asp-page-handler="SendVerificationEmail" class="text-blue-400 hover:underline text-xs mt-1">
                    Send bekreftelsese-post
                </button>
            }
        </div>

        <div class="mb-4">
            <label asp-for="Input.NewEmail" class="block text-sm font-medium text-gray-300 mb-1">Ny e-post</label>
            <input asp-for="Input.NewEmail" class="w-full bg-gray-700 border border-gray-600 text-white rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" autocomplete="email" aria-required="true" />
            <span asp-validation-for="Input.NewEmail" class="text-red-400 text-xs"></span>
        </div>

        <button id="change-email-button" type="submit" asp-page-handler="ChangeEmail" class="bg-blue-600 hover:bg-blue-700 text-white px-5 py-2 rounded-lg text-sm font-medium">
            Endre e-post
        </button>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}