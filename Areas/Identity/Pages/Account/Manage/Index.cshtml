@page
@model IndexModel
@{
    ViewData["Title"] = "Profil";
    ViewData["ActivePage"] = ManageNavPages.Index;
}

<partial name="_StatusMessage" for="StatusMessage" />

<div class="bg-gray-800 rounded-xl shadow border border-gray-700 p-6">
    <form id="profile-form" method="post">
        <div asp-validation-summary="ModelOnly" class="text-red-400 text-sm mb-4" role="alert"></div>

        <div class="mb-4">
            <label asp-for="Username" class="block text-sm font-medium text-gray-300 mb-1">Brukernavn</label>
            <input asp-for="Username" class="w-full bg-gray-700 border border-gray-600 rounded-lg px-3 py-2 text-sm text-gray-400 cursor-not-allowed" disabled />
        </div>

        <div class="mb-4">
            <label asp-for="Input.PhoneNumber" class="block text-sm font-medium text-gray-300 mb-1">Telefonnummer</label>
            <input asp-for="Input.PhoneNumber" class="w-full bg-gray-700 border border-gray-600 text-white rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 placeholder-gray-400" placeholder="Telefonnummer" />
            <span asp-validation-for="Input.PhoneNumber" class="text-red-400 text-xs"></span>
        </div>

        <button id="update-profile-button" type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-5 py-2 rounded-lg text-sm font-medium">
            Lagre
        </button>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}