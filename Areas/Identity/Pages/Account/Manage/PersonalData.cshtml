@page
@model PersonalDataModel
@{
    ViewData["Title"] = "Persondata";
    ViewData["ActivePage"] = ManageNavPages.PersonalData;
}

<div class="bg-white rounded-xl shadow p-6">
    <p class="text-sm text-gray-600 mb-2">Kontoen din inneholder persondata du har gitt oss. På denne siden kan du laste ned eller slette disse dataene.</p>
    <p class="text-sm text-red-600 font-medium mb-6">Sletting av disse dataene vil permanent fjerne kontoen din, og dette kan ikke angres.</p>

    <div class="flex gap-3">
        <form id="download-data" asp-page="DownloadPersonalData" method="post">
            <button class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg text-sm font-medium" type="submit">Last ned</button>
        </form>
        <a id="delete" asp-page="DeletePersonalData" class="bg-red-600 hover:bg-red-700 text-white px-4 py-2 rounded-lg text-sm font-medium">Slett konto</a>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}