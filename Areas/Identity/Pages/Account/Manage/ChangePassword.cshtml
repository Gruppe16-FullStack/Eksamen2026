@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Endre passord";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<partial name="_StatusMessage" for="StatusMessage" />

<div class="bg-gray-800 rounded-xl shadow border border-gray-700 p-6">
    <form id="change-password-form" method="post">
        <div asp-validation-summary="ModelOnly" class="text-red-400 text-sm mb-4" role="alert"></div>

        <div class="mb-4">
            <label asp-for="Input.OldPassword" class="block text-sm font-medium text-gray-300 mb-1">Gammelt passord</label>
            <input asp-for="Input.OldPassword" class="w-full bg-gray-700 border border-gray-600 text-white rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" autocomplete="current-password" aria-required="true" />
            <span asp-validation-for="Input.OldPassword" class="text-red-400 text-xs"></span>
        </div>

        <div class="mb-4">
            <label asp-for="Input.NewPassword" class="block text-sm font-medium text-gray-300 mb-1">Nytt passord</label>
            <input asp-for="Input.NewPassword" class="w-full bg-gray-700 border border-gray-600 text-white rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" autocomplete="new-password" aria-required="true" />
            <span asp-validation-for="Input.NewPassword" class="text-red-400 text-xs"></span>
        </div>

        <div class="mb-4">
            <label asp-for="Input.ConfirmPassword" class="block text-sm font-medium text-gray-300 mb-1">Bekreft nytt passord</label>
            <input asp-for="Input.ConfirmPassword" class="w-full bg-gray-700 border border-gray-600 text-white rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" autocomplete="new-password" aria-required="true" />
            <span asp-validation-for="Input.ConfirmPassword" class="text-red-400 text-xs"></span>
        </div>

        <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-5 py-2 rounded-lg text-sm font-medium">
            Oppdater passord
        </button>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}