@page
@model LogoutModel
@{
    ViewData["Title"] = "Logg ut";
}

<div class="max-w-md mx-auto text-center py-16">
    <h1 class="text-2xl font-bold text-gray-800 mb-4">Logg ut</h1>

    @if (User.Identity?.IsAuthenticated ?? false)
    {
        <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/", new { area = "" })" method="post">
            <button type="submit" class="bg-red-600 hover:bg-red-700 text-white px-6 py-2 rounded-lg text-sm font-medium">
                Logg ut
            </button>
        </form>
    }
    else
    {
        <p class="text-gray-500">Du har logget ut av applikasjonen.</p>
        <a asp-area="" asp-controller="Home" asp-action="Index" class="text-blue-600 hover:underline text-sm mt-4 inline-block">Gå til forsiden</a>
    }
</div>