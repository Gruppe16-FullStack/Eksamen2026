@model Pendlerapp.Models.Reisehistorikk

@{
    ViewData["Title"] = "Reisedetaljer";
    var forsinkelse = (int)(Model.FaktiskAvgangstid - Model.PlanlagtAvgangstid).TotalMinutes;
    var varForsinket = forsinkelse > 0;
}

<div class="max-w-lg mx-auto">
    <div class="mb-6">
        <h1 class="text-2xl font-bold text-white">@Model.Favoritt?.Navn</h1>
        <p class="text-gray-400 text-sm mt-1">@Model.PlanlagtAvgangstid.ToString("dd.MM.yyyy")</p>
    </div>

    <div class="bg-gray-800 rounded-xl shadow border border-gray-700 p-6 mb-4">
        <dl class="divide-y divide-gray-700">
            <div class="py-3 flex justify-between">
                <dt class="text-sm font-medium text-gray-400">Fra</dt>
                <dd class="text-sm text-white">@Model.Favoritt?.FraStoppested</dd>
            </div>
            <div class="py-3 flex justify-between">
                <dt class="text-sm font-medium text-gray-400">Til</dt>
                <dd class="text-sm text-white">@Model.Favoritt?.TilStoppested</dd>
            </div>
            <div class="py-3 flex justify-between">
                <dt class="text-sm font-medium text-gray-400">Reisetidspunkt</dt>
                <dd class="text-sm text-white">@Model.PlanlagtAvgangstid.ToString("HH:mm")</dd>
            </div>
            <div class="py-3 flex justify-between">
                <dt class="text-sm font-medium text-gray-400">Faktisk avgang</dt>
                <dd class="text-sm @(varForsinket ? "text-red-400" : "text-green-400")">
                    @Model.FaktiskAvgangstid.ToString("HH:mm")
                </dd>
            </div>
            <div class="py-3 flex justify-between">
                <dt class="text-sm font-medium text-gray-400">Status</dt>
                <dd class="text-sm">
                    @if (varForsinket)
                    {
                        <span class="bg-red-900 text-red-300 text-xs px-2 py-1 rounded">Forsinket +@forsinkelse min</span>
                    }
                    else if (forsinkelse < 0)
                    {
                        <span class="bg-blue-900 text-blue-300 text-xs px-2 py-1 rounded">@Math.Abs(forsinkelse) min tidlig</span>
                    }
                    else
                    {
                        <span class="bg-green-900 text-green-300 text-xs px-2 py-1 rounded">I rute</span>
                    }
                </dd>
            </div>
        </dl>
    </div>

    <div class="flex items-center justify-between">
        <a asp-action="Index" class="text-gray-400 hover:text-white text-sm">Tilbake til historikk</a>
        <a asp-action="Delete" asp-route-id="@Model?.Id" class="bg-red-600 hover:bg-red-700 text-white px-5 py-2 rounded-lg text-sm font-medium">Slett</a>
    </div>
</div>