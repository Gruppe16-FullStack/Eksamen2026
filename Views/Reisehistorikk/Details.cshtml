@model Pendlerapp.Models.Reisehistorikk

@{
    ViewData["Title"] = "Detaljer";
}

<div class="max-w-lg mx-auto">
    <div class="mb-6">
        <h1 class="text-2xl font-bold text-gray-800">Reisedetaljer</h1>
    </div>

    <div class="bg-white rounded-xl shadow p-6 mb-4">
        <dl class="divide-y divide-gray-100">
            <div class="py-3 flex justify-between">
                <dt class="text-sm font-medium text-gray-600">@Html.DisplayNameFor(model => model.Brukt)</dt>
                <dd class="text-sm text-gray-800">@Html.DisplayFor(model => model.Brukt)</dd>
            </div>
            <div class="py-3 flex justify-between">
                <dt class="text-sm font-medium text-gray-600">@Html.DisplayNameFor(model => model.FaktiskAvgangstid)</dt>
                <dd class="text-sm text-gray-800">@Html.DisplayFor(model => model.FaktiskAvgangstid)</dd>
            </div>
            <div class="py-3 flex justify-between">
                <dt class="text-sm font-medium text-gray-600">Favoritt</dt>
                <dd class="text-sm text-gray-800">@Html.DisplayFor(model => model.Favoritt.FraStoppested)</dd>
            </div>
        </dl>
    </div>

    <div class="flex items-center justify-between">
        <a asp-action="Index" class="text-gray-500 hover:underline text-sm">Tilbake til listen</a>
        <a asp-action="Edit" asp-route-id="@Model?.Id" class="bg-blue-600 hover:bg-blue-700 text-white px-5 py-2 rounded-lg text-sm font-medium">Rediger</a>
    </div>
</div>