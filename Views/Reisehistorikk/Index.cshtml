@model IEnumerable<Pendlerapp.Models.Reisehistorikk>

@{
    ViewData["Title"] = "Reisehistorikk";
}

<div class="max-w-5xl mx-auto">
    <div class="flex items-center justify-between mb-6">
        <h1 class="text-2xl font-bold text-white">Reisehistorikk</h1>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-16 text-gray-400">
            <p class="text-lg">Ingen reiser registrert ennå.</p>
            <p class="text-sm mt-2">Velg en avgang fra dine favoritter for å logge en reise.</p>
        </div>
    }
    else
    {
        <div class="bg-gray-800 rounded-xl shadow border border-gray-700 overflow-hidden">
            <table class="w-full text-sm text-left">
                <thead class="bg-gray-700 text-gray-400 uppercase text-xs">
                    <tr>
                        <th class="px-4 py-3">Rute</th>
                        <th class="px-4 py-3">Reisetidspunkt</th>
                        <th class="px-4 py-3">Forsinket</th>
                        <th class="px-4 py-3"></th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-700">
                    @foreach (var item in Model)
                    {
                        var forsinkelse = (int)(item.FaktiskAvgangstid - item.PlanlagtAvgangstid).TotalMinutes;
                        var varForsinket = forsinkelse > 0;

                        <tr class="hover:bg-gray-750">
                            <td class="px-4 py-3 font-medium text-white">@item.Favoritt?.Navn</td>
                            <td class="px-4 py-3 text-gray-300">@item.PlanlagtAvgangstid.ToString("dd.MM.yyyy HH:mm")</td>
                            <td class="px-4 py-3">
                                @if (varForsinket)
                                {
                                    <span class="bg-red-900 text-red-300 text-xs px-2 py-1 rounded">+@forsinkelse min</span>
                                }
                                else
                                {
                                    <span class="bg-green-900 text-green-300 text-xs px-2 py-1 rounded">I rute</span>
                                }
                            </td>
                            <td class="px-4 py-3 flex gap-3 text-sm">
                                <a asp-action="Details" asp-route-id="@item.Id" class="text-gray-400 hover:underline">Detaljer</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="text-red-400 hover:underline">Slett</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>