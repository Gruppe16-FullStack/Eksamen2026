@model IEnumerable<Pendlerapp.Models.Reisehistorikk>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Brukt)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.FaktiskAvgangstid)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Favoritt)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Brukt)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.FaktiskAvgangstid)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Favoritt.FraStoppested)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
