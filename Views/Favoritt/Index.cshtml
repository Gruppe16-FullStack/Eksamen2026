@model IEnumerable<Pendlerapp.Models.Favoritt>

@{
    ViewData["Title"] = "Mine favoritter";
}

<h1>Mine favoritter</h1>

<p>
    <a asp-action="Create">Opprett ny</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Navn)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.FraStoppested)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.TilStoppested)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Opprettet)
            </th>
            <th>
                Antall reiser
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.Navn)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.FraStoppested)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.TilStoppested)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Opprettet)
                </td>
                <td>
                    @item.Reisehistorikker.Count()
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>