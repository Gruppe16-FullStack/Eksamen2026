@model Pendlerapp.Models.Favoritt

@{
    ViewData["Title"] = "Rediger favoritt";
}

<div class="max-w-lg mx-auto">
    <div class="mb-6">
        <h1 class="text-2xl font-bold text-white">Rediger favoritt</h1>
    </div>

    <div class="bg-gray-800 rounded-xl shadow border border-gray-700 p-6">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-red-400 text-sm mb-4"></div>
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="Opprettet" />
            <input type="hidden" asp-for="BrukerId" />

            <div class="mb-4">
                <div class="flex items-center gap-2 mb-1">
                    <label asp-for="Navn" class="block text-sm font-medium text-gray-300"></label>
                    <div class="relative group">
                        <span class="w-4 h-4 rounded-full bg-gray-600 text-gray-300 text-xs flex items-center justify-center cursor-pointer">?</span>
                        <div class="absolute left-6 top-0 w-56 bg-gray-900 text-white text-xs rounded-lg px-3 py-2 hidden group-hover:block z-10 border border-gray-600">
                            Dette er kallenavnet du gir ruten din, f.eks. "Jobb" eller "Hjem fra trening".
                        </div>
                    </div>
                </div>
                <input asp-for="Navn" class="w-full bg-gray-700 border border-gray-600 text-white rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 placeholder-gray-400" />
                <span asp-validation-for="Navn" class="text-red-400 text-xs"></span>
            </div>

            <div class="mb-4 relative">
                <label class="block text-sm font-medium text-gray-300 mb-1">Fra stoppested</label>
                <input type="text" id="fra-sok" value="@Model.FraStoppested" placeholder="Søk etter stoppested..." autocomplete="off"
                    class="w-full bg-gray-700 border border-gray-600 text-white rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 placeholder-gray-400" />
                <ul id="fra-liste" class="absolute z-20 w-full bg-gray-800 border border-gray-600 rounded-lg shadow mt-1 hidden"></ul>
                <input asp-for="FraStoppested" type="hidden" />
                <input asp-for="FraStoppestedId" type="hidden" />
                <span asp-validation-for="FraStoppested" class="text-red-400 text-xs"></span>
            </div>

            <div class="mb-4 relative">
                <label class="block text-sm font-medium text-gray-300 mb-1">Til stoppested</label>
                <input type="text" id="til-sok" value="@Model.TilStoppested" placeholder="Søk etter stoppested..." autocomplete="off"
                    class="w-full bg-gray-700 border border-gray-600 text-white rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 placeholder-gray-400" />
                <ul id="til-liste" class="absolute z-20 w-full bg-gray-800 border border-gray-600 rounded-lg shadow mt-1 hidden"></ul>
                <input asp-for="TilStoppested" type="hidden" />
                <input asp-for="TilStoppestedId" type="hidden" />
                <span asp-validation-for="TilStoppested" class="text-red-400 text-xs"></span>
            </div>

            <div class="flex items-center justify-between mt-6">
                <a asp-action="Index" class="text-gray-400 hover:text-white text-sm">Tilbake til listen</a>
                <input type="submit" value="Lagre" class="bg-blue-600 hover:bg-blue-700 text-white px-5 py-2 rounded-lg text-sm font-medium cursor-pointer" />
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        function setupSok(sokFeltId, listeId, navnFeltNavn, idFeltNavn) {
            const sokFelt = document.getElementById(sokFeltId);
            const liste = document.getElementById(listeId);
            const navnFelt = document.querySelector(`input[name="${navnFeltNavn}"]`);
            const idFelt = document.querySelector(`input[name="${idFeltNavn}"]`);
            let debounceTimer;
            sokFelt.addEventListener('input', () => {
                clearTimeout(debounceTimer);
                const query = sokFelt.value.trim();
                if (query.length < 2) { liste.classList.add('hidden'); return; }
                debounceTimer = setTimeout(async () => {
                    const response = await fetch(`/Favoritt/SokStoppested?navn=${encodeURIComponent(query)}`);
                    const data = await response.json();
                    liste.innerHTML = '';
                    if (data.length === 0) { liste.classList.add('hidden'); return; }
                    data.forEach(item => {
                        const li = document.createElement('li');
                        li.textContent = item.label;
                        li.className = 'px-3 py-2 text-sm text-gray-300 hover:bg-gray-700 cursor-pointer';
                        li.addEventListener('click', () => {
                            sokFelt.value = item.label;
                            navnFelt.value = item.navn;
                            idFelt.value = item.id;
                            liste.classList.add('hidden');
                        });
                        liste.appendChild(li);
                    });
                    liste.classList.remove('hidden');
                }, 300);
            });
            document.addEventListener('click', (e) => {
                if (!sokFelt.contains(e.target) && !liste.contains(e.target)) liste.classList.add('hidden');
            });
        }
        setupSok('fra-sok', 'fra-liste', 'FraStoppested', 'FraStoppestedId');
        setupSok('til-sok', 'til-liste', 'TilStoppested', 'TilStoppestedId');
    </script>
}