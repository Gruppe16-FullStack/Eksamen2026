@model Pendlerapp.Models.Favoritt

@{
    ViewData["Title"] = "Slett favoritt";
}

<div class="max-w-lg mx-auto">
    <div class="mb-6">
        <h1 class="text-2xl font-bold text-gray-800">Slett favoritt</h1>
        <p class="text-gray-500 mt-1">Er du sikker på at du vil slette denne favoritten?</p>
    </div>

    <div class="bg-white rounded-xl shadow p-6 mb-4">
        <dl class="divide-y divide-gray-100">
            <div class="py-3 flex justify-between">
                <dt class="text-sm font-medium text-gray-600">@Html.DisplayNameFor(model => model.Navn)</dt>
                <dd class="text-sm text-gray-800">@Html.DisplayFor(model => model.Navn)</dd>
            </div>
            <div class="py-3 flex justify-between">
                <dt class="text-sm font-medium text-gray-600">@Html.DisplayNameFor(model => model.FraStoppested)</dt>
                <dd class="text-sm text-gray-800">@Html.DisplayFor(model => model.FraStoppested)</dd>
            </div>
            <div class="py-3 flex justify-between">
                <dt class="text-sm font-medium text-gray-600">@Html.DisplayNameFor(model => model.TilStoppested)</dt>
                <dd class="text-sm text-gray-800">@Html.DisplayFor(model => model.TilStoppested)</dd>
            </div>
            <div class="py-3 flex justify-between">
                <dt class="text-sm font-medium text-gray-600">@Html.DisplayNameFor(model => model.Opprettet)</dt>
                <dd class="text-sm text-gray-800">@Html.DisplayFor(model => model.Opprettet)</dd>
            </div>
        </dl>
    </div>

    <form asp-action="Delete" class="flex items-center justify-between">
        <input type="hidden" asp-for="Id" />
        <a asp-action="Index" class="text-gray-500 hover:underline text-sm">Avbryt</a>
        <input type="submit" value="Slett" class="bg-red-600 hover:bg-red-700 text-white px-5 py-2 rounded-lg text-sm font-medium cursor-pointer" />
    </form>
</div>