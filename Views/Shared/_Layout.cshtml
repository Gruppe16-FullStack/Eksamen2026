<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Pendlerapp</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/css/output.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="min-h-screen flex flex-col bg-gray-50">
    <header>
        <nav class="bg-white border-b shadow-sm mb-6">
            <div class="max-w-7xl mx-auto px-4 flex items-center justify-between h-14">
                <a class="text-lg font-semibold text-gray-800" asp-area="" asp-controller="Home" asp-action="Index">Pendlerapp</a>
                <ul class="flex gap-6">
                    <li>
                        <a class="text-gray-600 hover:text-gray-900" asp-area="" asp-controller="Home" asp-action="Index">Hjem</a>
                    </li>
                    <li>
                        <a class="text-gray-600 hover:text-gray-900" asp-area="" asp-controller="Favoritt" asp-action="Index">Mine favoritter</a>
                    </li>
                    <li>
                        <a class="text-gray-600 hover:text-gray-900" asp-area="" asp-controller="Home" asp-action="Privacy">Personvern</a>
                    </li>
                </ul>
            </div>
        </nav>
    </header>

    <div class="max-w-7xl mx-auto px-4 w-full flex-grow">
        <main role="main" class="pb-6">
            @RenderBody()
        </main>
    </div>

    <footer class="border-t bg-white text-gray-500 text-sm">
        <div class="max-w-7xl mx-auto px-4 py-3">
            &copy; 2026 - Pendlerapp
        </div>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
