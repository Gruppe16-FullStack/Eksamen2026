<!DOCTYPE html>
<html lang="no">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Pendlerapp</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/css/output.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="min-h-screen flex flex-col bg-gray-900 text-gray-100">
    <header>
        <nav class="bg-gray-800 border-b border-gray-700 mb-6">
            <div class="max-w-7xl mx-auto px-4 flex items-center justify-between h-14">
                <a class="text-lg font-semibold text-white" asp-area="" asp-controller="Home" asp-action="Index">🚆 Pendlerapp</a>
                <ul class="flex gap-6 items-center">
                    <li>
                        <a class="text-gray-300 hover:text-white text-sm" asp-area="" asp-controller="Home" asp-action="Index">Hjem</a>
                    </li>
                    <li>
                        <a class="text-gray-300 hover:text-white text-sm" asp-area="" asp-controller="Favoritt" asp-action="Index">Mine favoritter</a>
                    </li>
                    <li>
                        <a class="text-gray-300 hover:text-white text-sm" asp-area="" asp-controller="Reisehistorikk" asp-action="Index">Reisehistorikk</a>
                    </li>
                    <li>
                        <a class="text-gray-300 hover:text-white text-sm" asp-area="" asp-controller="Home" asp-action="Privacy">Personvern</a>
                    </li>
                    <partial name="_LoginPartial" />
                </ul>
            </div>
        </nav>
    </header>

    <div class="max-w-7xl mx-auto px-4 w-full flex-grow">
        <main role="main" class="pb-6">
            @RenderBody()
        </main>
    </div>

    <footer class="border-t border-gray-700 bg-gray-800 text-gray-500 text-sm mt-6">
        <div class="max-w-7xl mx-auto px-4 py-3">
            &copy; 2026 - Pendlerapp
        </div>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>